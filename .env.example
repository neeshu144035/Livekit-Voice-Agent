# Next.js frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880
BACKEND_API_URL=http://127.0.0.1:8000
INTERNAL_API_URL=http://127.0.0.1:8000

# Backend
DATABASE_URL=postgresql://admin:password123@localhost:5432/dashboard_db
REDIS_URL=redis://localhost:6379
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_WS_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=change-me
LIVEKIT_SIP_ENDPOINT=127.0.0.1:5060

# Dashboard auth
DASHBOARD_ADMIN_EMAIL=admin@example.com
DASHBOARD_ADMIN_PASSWORD=change-me
AUTH_SESSION_SECRET=change-me
AUTH_SESSION_COOKIE=session_token
AUTH_SESSION_MAX_AGE=604800
AUTH_SECURE_COOKIES=false

# LLM / speech providers
OPENAI_API_KEY=
MOONSHOT_API_KEY=
DEEPGRAM_API_KEY=
ELEVEN_API_KEY=
ELEVENLABS_API_KEY=
XAI_API_KEY=

# Voice worker
DASHBOARD_API_URL=http://host.docker.internal:8000
LIVEKIT_WORKER_AGENT_NAME=sarah
MAX_CALL_DURATION=1800
STRICT_PROMPT_TOOL_FILTER=1
DEEPGRAM_STT_PHONE_MODEL=nova-3
DEEPGRAM_STT_WEB_MODEL=nova-3
XAI_REALTIME_MODEL=grok-voice-think-fast-1.0
XAI_REALTIME_BASE_URL=https://api.x.ai/v1
